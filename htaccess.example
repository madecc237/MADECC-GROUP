# Apache Rewrite Rules for React Single Page Application (SPA)
# Place this file inside your cPanel public_html (or root directory of your static domain) as ".htaccess"

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # If the requested filename exists as a real file or directory, serve it directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  
  # For any other requested path, rewrite to your SPA's entry point (index.html)
  RewriteRule ^ index.html [L]
</IfModule>
